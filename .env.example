# Azure OpenAI — SwissHacks endpoint (services.ai.azure.com, AI Foundry project).
# Priority: Azure > Google Gemini > Public AI (Apertus) > offline stub.
# Get key + endpoint from hackathon organizers.
AZURE_API_KEY=
AZURE_API_BASE=https://swisshacks11languages-resource.services.ai.azure.com/
AZURE_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_REASONING=gpt-4.1-mini  # deployed model name (not model id)
AZURE_OPENAI_DEPLOYMENT_DEEP=gpt-4.1-mini       # update if a stronger model is deployed

# Google API key (for Google ADK / Gemini models).
GOOGLE_API_KEY=

# Public AI (publicai.co) — Apertus 8B and 70B, CSCS-funded, free for hackathon.
# Sign up at https://platform.publicai.co → API Keys → Create key.
# Endpoint: https://api.publicai.co/v1 (OpenAI-compatible)
PUBLICAI_API_KEY=

# CORS: origin the backend allows (the Next.js dev server).
FRONTEND_ORIGIN=http://localhost:3000

# Frontend: where the browser reaches the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
