# Azure OpenAI — SwissHacks endpoint (services.ai.azure.com, AI Foundry project).
# Priority: Azure > Google Gemini > Public AI (Apertus) > offline stub.
# Get key + endpoint from hackathon organizers.
AZURE_API_KEY=
AZURE_API_BASE=https://swisshacks11languages-resource.services.ai.azure.com/
AZURE_API_VERSION=2024-08-01-preview
# Set these to deployment names that actually exist in your Azure resource.
# Discover live ones with: python scripts/list_models.py  /  python scripts/probe_deployments.py
AZURE_OPENAI_DEPLOYMENT_REASONING=gpt-4.1-mini   # step 2 mid-tier deployment name
AZURE_OPENAI_DEPLOYMENT_DEEP=gpt-4.1-mini        # step 3 deep deployment name

# Google API key (for Google ADK / Gemini models).
GOOGLE_API_KEY=

# Public AI (publicai.co) — Apertus 8B and 70B, CSCS-funded, free for hackathon.
# Sign up at https://platform.publicai.co → API Keys → Create key.
# Endpoint: https://api.publicai.co/v1 (OpenAI-compatible)
PUBLICAI_API_KEY=

# CORS: origin the backend allows (the Next.js dev server).
FRONTEND_ORIGIN=http://localhost:3000

# Frontend: where the browser reaches the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Frontend: opt into live mode. Off (or unset) keeps the cockpit a self-contained
# mock demo (localStorage seed); "true" drives it from the backend, falling back to
# the mock if the backend is slow or offline.
NEXT_PUBLIC_USE_BACKEND=false
