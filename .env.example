# Azure OpenAI, used via Google ADK + LiteLLM (read only by the backend).
# If these are unset, the pipeline still runs end to end using a labelled offline stub.
AZURE_API_KEY=
AZURE_API_BASE=https://<your-resource>.openai.azure.com
AZURE_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_REASONING=gpt-4o-mini   # step 2 mid-tier deployment name
AZURE_OPENAI_DEPLOYMENT_DEEP=gpt-4o             # step 3 deep deployment name

# Google API key (for Google ADK / Gemini models).
GOOGLE_API_KEY=

# Public AI (publicai.co) — Apertus 8B and 70B, CSCS-funded, free for hackathon.
# Sign up at https://platform.publicai.co → API Keys → Create key.
# Endpoint: https://api.publicai.co/v1 (OpenAI-compatible)
PUBLICAI_API_KEY=

# CORS: origin the backend allows (the Next.js dev server).
FRONTEND_ORIGIN=http://localhost:3000

# Frontend: where the browser reaches the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
